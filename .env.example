# Neon (read-only) — pelo menos uma URL para modo live
NEON_BRASIL_DATABASE_URL=
NEON_IGUATEMI_DATABASE_URL=

# Auth Waltter (obrigatório em produção)
CEREBRO_ADMIN_USER=waltter
CEREBRO_ADMIN_PASSWORD=

# Sentry (Next.js) — projeto rom-cerebro na org imobi-hl
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Resend — alertas de saúde por e-mail (severidade crítica)
# Pode reutilizar a mesma RESEND_API_KEY dos projetos ROM
RESEND_API_KEY=
ALERT_EMAIL_TO=contato.vinicaetano93@gmail.com
# Opcional — remetente (precisa de domínio verificado no Resend; senão usa onboarding@resend.dev)
# RESEND_FROM=Cérebro ROM <onboarding@resend.dev>

# Forçar mock mesmo com Neon configurado
# CEREBRO_FORCE_MOCK=1

# Metas e capacidade — preferir preencher no painel (Metas).
# Env só como bootstrap opcional se a tabela cerebro_goals ainda estiver vazia.
# BRASIL_DAILY_GOAL=
# BRASIL_DAILY_CAPACITY=
# IGUATEMI_DAILY_GOAL=
# IGUATEMI_DAILY_CAPACITY=
